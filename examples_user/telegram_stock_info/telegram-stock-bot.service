[Unit]
Description=Telegram Stock Analysis Bot
After=network.target

[Service]
Type=simple
User=boyeon
WorkingDirectory=/home/boyeon/workspace/open-trading-api/examples_user/telegram_stock_info
Environment="TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here"
ExecStart=/usr/bin/uv run bot.py
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target